model OrganizationAiSettings {
  organizationId  String   @id
  defaultModelId  String   @db.VarChar(100)
  allowedModelIds String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AiConversation {
  id              String   @id @default(cuid())
  organizationId  String
  createdByUserId String
  surface         String   @db.VarChar(120)
  title           String   @db.VarChar(120)
  messagesJson    Json
  lastMessageAt   DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User         @relation("AiConversationToUser", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdByUserId, surface, lastMessageAt(sort: Desc)])
  @@index([createdByUserId])
  @@index([organizationId])
}
