model StoredFile {
  id               String   @id @default(cuid())
  organizationId   String
  uploadedByUserId String
  storageKey       String   @unique @db.VarChar(255)
  fileName         String   @db.VarChar(255)
  contentType      String   @db.VarChar(120)
  sizeBytes        Int
  createdAt        DateTime @default(now())

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy      User             @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  taskAttachments TaskAttachment[]

  @@index([organizationId, createdAt(sort: Desc)])
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       Int
  storedFileId String
  createdAt    DateTime @default(now())

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  storedFile StoredFile @relation(fields: [storedFileId], references: [id], onDelete: Cascade)

  @@unique([taskId, storedFileId])
  @@index([storedFileId])
}

model TwoFactor {
  id          String  @id @default(cuid())
  userId      String  @unique
  secret      String  @db.Text
  backupCodes String  @db.Text
  enabled     Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
