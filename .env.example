# Example .env file.
# Keep this as `.env`, not `.env.local`, unless you also change the app config.

# Database
POSTGRES_URL=postgresql://***

# Stripe core
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***

# Stripe price IDs for paid plans.
# These four values are required for paid plans to show up in billing and pricing UI.
STRIPE_PRICE_PRO_MONTHLY=price_***
STRIPE_PRICE_PRO_YEARLY=price_***
STRIPE_PRICE_TEAM_MONTHLY=price_***
STRIPE_PRICE_TEAM_YEARLY=price_***

# App URLs and auth
BASE_URL=http://localhost:3000
AUTH_SECRET=***
BETTER_AUTH_API_KEY=

# When "true" (default), new accounts can sign in immediately without verifying their email.
# Set to "false" in production to require email verification.
SKIP_EMAIL_VERIFICATION=true

# Stripe billing behavior
STRIPE_ENABLE_TRIAL_WITHOUT_CC=false
ENABLE_AUTOMATIC_TAX_CALCULATION=false
ENABLE_TAX_ID_COLLECTION=false
STRIPE_REQUIRE_BILLING_ADDRESS=false

# Email
RESEND_API_KEY=re_***
EMAIL_FROM=Acme <hello@example.com>
EMAIL_REPLY_TO=
# Recipient for the marketing contact form.
# When unset, falls back to the EMAIL_FROM address.
CONTACT_FORM_TO=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Set to "true" to enable automatic OAuth account linking by email.
# Safe when all providers verify email addresses (Google and GitHub do).
ALLOW_EMAIL_ACCOUNT_LINKING=true

# Account mode: "personal-only" | "organizations-only"
# Defaults to "organizations-only" if not set.
NEXT_PUBLIC_ACCOUNT_MODE=organizations-only

# Marketing site: Gumroad, Lemon Squeezy, or Stripe Payment Link for starter checkout.
# Each tier gets its own URL. When unset, pricing CTAs scroll to #pricing.
# NEXT_PUBLIC_STARTER_PURCHASE_URL_SOLO=https://buy.stripe.com/...
# NEXT_PUBLIC_STARTER_PURCHASE_URL_TEAM=https://buy.stripe.com/...

# Optional live demo URL shown as the "Demo" link in the marketing header.
# When unset, the link falls back to /sign-in.
# NEXT_PUBLIC_DEMO_URL=https://demo.example.com

# Rate limiting (Upstash Redis).
# Create a free database at https://console.upstash.com/redis and copy the REST URL + token.
# When unset, rate limiting is a no-op (fine in dev; a warning is logged in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Demo mode.
# When "true": blocks destructive actions, enables the daily DB reset cron.
# Use for public demo deployments only. Leave unset in production.
DEMO_MODE=false
# Secret required by Vercel Cron to call /api/demo/reset.
CRON_SECRET=

# Error tracking (Sentry).
# Create a project at https://sentry.io and copy the DSN.
# SENTRY_AUTH_TOKEN is only needed in CI/production to upload source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional overrides:
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
